            <image>https://raw.githubusercontent.com/Nasc1mento/xppc-app/master/screenshots/success_dark.png</image>
        </screenshot>
    </screenshots>

    <url type="homepage">https://github.com/Nasc1mento/xppc-app</url>
    <url type="vcs-browser">https://github.com/Nasc1mento/xppc-app</url>

